{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Technology",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer"
    },
    "technology": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": ["id", "name", "language", "type"]
    },
    "metadata": {
      "type": "object",
      "properties": {
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "owner": {
            "type": "string"
          },
          "repo": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "technologies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "official": {
            "type": "boolean"
          },
          "verified": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": ["owner", "repo", "kind"]
      }
    }
  },
  "required": ["version", "technology"]
}
